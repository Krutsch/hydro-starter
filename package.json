{
  "name": "hydro-starter",
  "version": "1.0.0",
  "description": "A starter Web App for hydro-js",
  "type": "module",
  "scripts": {
    "start": "html-bundle --hmr --secure --handler utils/staticFiles.js",
    "build": "html-bundle --isCritical --handler utils/staticFiles.js",
    "lint": "eslint src/**/*.{ts,js,mjs,jsx,tsx} --fix && tsc --noEmit",
    "format": "prettier --write .",
    "test": "playwright test",
    "update": "npx npm-check-updates -u && npm i && npm outdated"
  },
  "dependencies": {
    "comlink": "^4.4.2",
    "hydro-js": "^1.8.15",
    "progressive-picture": "^3.1.3",
    "workbox-cacheable-response": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@esm-bundle/chai": "^4.3.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "cssnano": "^7.1.5",
    "cssnano-preset-advanced": "^7.0.13",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "html-bundle": "^6.2.2",
    "node-json-minify": "^3.0.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
