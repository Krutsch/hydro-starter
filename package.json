{
  "name": "hydro-starter",
  "version": "1.0.0",
  "description": "A starter Web App for hydro-js",
  "type": "module",
  "scripts": {
    "start": "html-bundle --hmr --secure --handler utils/staticFiles.js",
    "build": "html-bundle --isCritical --handler utils/staticFiles.js",
    "lint": "eslint src/**/*.{ts,js,mjs,jsx,tsx} --fix && tsc --noEmit",
    "format": "prettier --write .",
    "test": "playwright test",
    "update": "npx npm-check-updates -u && npm i && npm outdated"
  },
  "dependencies": {
    "comlink": "^4.4.2",
    "hydro-js": "^1.9.1",
    "progressive-picture": "^3.1.3",
    "workbox-cacheable-response": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@esm-bundle/chai": "^4.3.4",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^26.1.1",
    "cssnano": "^8.0.2",
    "cssnano-preset-advanced": "^8.0.2",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "html-bundle": "^6.5.1",
    "node-json-minify": "^3.0.0",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
